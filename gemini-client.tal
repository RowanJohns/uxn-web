( gemini client for UXN )
|00 @System [ &vector $2 &pad $6 &r $2 &g $2 &b $2 ] 
|0e @System/debug $1
|10 @Console [ &vector $2 &read $1 &pad $5 &write $1 &error $1 ]
|20 @Screen [ &vector $2 &width $2 &height $2 &auto $1 &pad $1 &x $2 &y $2 &addr $2 &pixel $1 &sprite $1 ]
|80 @Controller [ &vector $2 &button $1 &key $1 ]
|90 @Mouse [ &vector $2 &x $2 &y $2 &state $1 &pad $3 &scrollx $2 &scrolly $2 ]
|a0 @Network [ &vector $2 &state $1 &type $1 &host $2 &port $2 &length $2 &read $2 &write $2 &tls $1 ]

( macros )
%DBG ( -- ) { [ LIT2 01 -System/debug ] DEO }
( print a character to standard output )
%EMIT { .Console/write DEO } ( character -- )
( print a newline )
%NL { #0a EMIT } ( -- )
( add CRLF )
%CRLF { #0d0a }

( zero page )
|0000
@pointer [ &x $2 &y $2 ]
@cursor [ &x $2 &y $2 ]
@move-cursor [ &x $2 &y $2 ]
@scroll [ &top $2 &bottom $2 ]
@search-cursor [ &x $2 ]
@lines [ &total $2 &blocks $2 ]

|0100 ( -> )

  ( set screen size )
#0300 .Screen/width DEO2
#0200 .Screen/height DEO2

  ( set system colors )
  #f400 .System/r DEO2
  #f300 .System/g DEO2
  #e000 .System/b DEO2
  
  #0008 .cursor/x STZ2
  #0008 .cursor/y STZ2
  #0008 .move-cursor/x STZ2
  #0008 .move-cursor/y STZ2
  #002a .scroll/top STZ2

  ;draw/searchbar JSR2
  ;draw/scrollbox JSR2

  ( set mouse vector )
  ;on-mouse .Mouse/vector DEO2

  ( Set network callback )
  ;on-network .Network/vector DEO2

  ( Configure as TCP client )
  #00 .Network/type DEO

  ( Configure TLS on )
  #01 .Network/tls DEO
  
  ( Set target host and port )
  ;host .Network/host DEO2

  ( port 1965 for gemini )
  #07ad .Network/port DEO2

  ( Keyboard callback )
  ;type/url .Controller/vector DEO2

BRK

@print/string ( string* -- )
    LDAk ?{ NL POP2 JMP2r }
    LDAk EMIT
    INC2 !/string

@on-network ( -> )
  .Network/state DEI
  #02 EQU ?&connected
  POP BRK
  
  &connected
      ( Send gemini URL request )
    #0080 .Network/length DEO2
      #00 ;buffer ;buffer-pointer LDA2 ADD2 STA ( null terminate the request )
      ;buffer .Network/write DEO2
      ( Read response )
      #ffff .Network/length DEO2
      ;response .Network/read DEO2
      #0008 .cursor/x STZ2
      #001f .cursor/y STZ2
      ;response ;line-breaks STA2
      ;response ;draw/text JSR2
      ( make sure no more line break addresses are stored )
      ;lb-pointer LDA2 #0001 ADD2 ;lb-pointer-max STA2
      ( store number of blocks of text )
      .lines/total LDZ2 #001e DIV2 #0000 NEQ ?{ INC2 } .lines/blocks STZ2
      ( determine where bottom of scrollbar should be )
      #01cc .lines/blocks LDZ2 DIV2 #002a ADD2 .scroll/bottom STZ2
      ;draw/scrollbar JSR2
BRK

@draw/searchbar
  #0005 .Screen/x DEO2
  #0008 .Screen/y DEO2
  ( draw left corners )
  ;left-corner .Screen/addr DEO2
  #0a .Screen/sprite DEO
  #000f .Screen/y DEO2
  ;left-corner #0008 ADD2 .Screen/addr DEO2
  #0a .Screen/sprite DEO
  ( draw right corners )
  #0200 .Screen/x DEO2
  #0008 .Screen/y DEO2
  ;right-corner .Screen/addr DEO2
  #0a .Screen/sprite DEO
  #000f .Screen/y DEO2
  ;right-corner #0008 ADD2 .Screen/addr DEO2
  #0a .Screen/sprite DEO
  ( draw middle lines )
  #000c .Screen/x DEO2
  #0008 .Screen/y DEO2
  &middle
      ;middle-lines .Screen/addr DEO2
      #0a .Screen/sprite DEO
      #000f .Screen/y DEO2
      ;middle-lines #0008 ADD2 .Screen/addr DEO2
      #0a .Screen/sprite DEO
      #0008 .Screen/y DEO2
      #0008 .Screen/x DEI2 ADD2 .Screen/x DEO2
      #0200 .Screen/x DEI2 LTH2 ?{ !&middle }
JMP2r

@draw/scrollbar
  ( draw top scroll block )
  .scroll/top LDZ2 .Screen/y DEO2
  #02ef .Screen/x DEO2
  [ LIT2 16 -Screen/auto ] DEO
  ;scroll-top .Screen/addr DEO2
  #0a .Screen/sprite DEO
  ( don't overflow bottom of scrollbar )
  .scroll/bottom LDZ2 #01ef LTH2k ?{ SWP2 POP2 #0000 }
  POP2 .scroll/bottom STZ2
  ( draw middle )
  &block
      ;scroll-middle .Screen/addr DEO2
      #0a .Screen/sprite DEO
      #02ef .Screen/x DEO2
      .scroll/bottom LDZ2 .Screen/y DEI2 LTH2 ?{ !&block }
  ( draw bottom scroll block )
  #02ef .Screen/x DEO2
  .scroll/bottom LDZ2 .Screen/y DEO2
  ;scroll-bottom .Screen/addr DEO2
  #0a .Screen/sprite DEO
  [ LIT2 00 -Screen/auto ] DEO
JMP2r

@draw/scrollbox
  #02ef .Screen/x DEO2
  #0028 .Screen/y DEO2
  ( draw top corners )
  ;top-corner .Screen/addr DEO2
  #0a .Screen/sprite DEO
  #02f7 .Screen/x DEO2
  ;top-corner #0008 ADD2 .Screen/addr DEO2
  #0a .Screen/sprite DEO
  ( draw bottom corners )
  #02ef .Screen/x DEO2
  #01f0 .Screen/y DEO2
  ;bottom-corner .Screen/addr DEO2
  #0a .Screen/sprite DEO
  #02f7 .Screen/x DEO2
  ;bottom-corner #0008 ADD2 .Screen/addr DEO2
  #0a .Screen/sprite DEO
  ( draw vertical lines )
  #02ef .Screen/x DEO2
  #002f .Screen/y DEO2
  &vertical
      [ LIT2 16 -Screen/auto ] DEO
      ;vertical-lines .Screen/addr DEO2
      #0a .Screen/sprite DEO
      #02ef .Screen/x DEO2
      #01f0 .Screen/y DEI2 LTH2 ?{ !&vertical }
      [ LIT2 00 -Screen/auto ] DEO
JMP2r

@clear/screen
  #0008 .Screen/x DEO2
  #001f .Screen/y DEO2
  [ LIT2 80 -Screen/pixel ] DEO
JMP2r

@draw/pointer
  ( send pointer position to screen )
  .pointer/x LDZ2 .Screen/x DEO2
  .pointer/y LDZ2 .Screen/y DEO2
  ( clear sprite from foreground )
  ;pointer-icn .Screen/addr DEO2
  #40 .Screen/sprite DEO
  ( update pointer position )
  .Mouse/x DEI2 .pointer/x STZ2
  .Mouse/y DEI2 .pointer/y STZ2
  ( send pointer position to screen )
  .pointer/x LDZ2 .Screen/x DEO2
  .pointer/y LDZ2 .Screen/y DEO2
  ( draw sprite in foreground )
  ;pointer-icn .Screen/addr DEO2
  #4a .Screen/sprite DEO
JMP2r

@on-mouse
  [ LIT2 00 -Screen/auto ] DEO 
  ;draw/pointer JSR2
  ( if click, scroll page )
  .Mouse/state DEI #01 EQU ?{ BRK }
  ( check if scrollbar has been clicked )
  .Mouse/x DEI2 #02ef GTH2k #00 SWP2 POP2 SWP2 #02f8 LTH2 ROT AND ?{ POP BRK }
  POP
  .Mouse/y DEI2 #0027 GTH2k #00 SWP2 POP2 SWP2 #01ff LTH2 ROT AND ?{ POP BRK }
  POP
  ( only draw scrollbar starting from top of scroll box )
  .Mouse/y DEI2 #002a GTH2k ?{ SWP2 POP2 #0000 }
  POP2 DUP2 .scroll/top STZ2
  #01cc .lines/blocks LDZ2 DIV2 .scroll/top LDZ2 ADD2 .scroll/bottom STZ2
  ;clear/screen JSR2
  ;draw/scrollbox JSR2
  ;draw/scrollbar JSR2
  ( is there anything in the response? )
  ;response LDA2 #00 NEQ ?{ BRK }
  ( draw the new section )
  #0008 .cursor/x STZ2
  #001f .cursor/y STZ2
  ( get the new top line index TODO: MAKE THIS WORK!!! )
  .scroll/top LDZ2 #002a SUB2 .lines/total LDZ2 MUL2 #01cc DIV2 #0002 MUL2 DBG
  ( get addr for that line in response response=#385X )
  ;line-breaks ADD2 LDA2
  ;draw/text JSR2
  ( put the cursor back for typing in the search bar )
  .search-cursor/x LDZ2 .cursor/x STZ2
  #0008 .cursor/y STZ2
BRK

@delete/key
  ( check that there is something to delete )
  ;char LDA #00 NEQ ?{ BRK }
  ( remove letter from buffer )
  #00 ;buffer ;buffer-pointer LDA2 #0001 SUB2 ADD2 STA
  ;buffer-pointer LDA2 #0001 SUB2 ;buffer-pointer STA2
  ( erase letter from screen )
  ;char LDA
  #0000 ROT
  ;widths ADD2 LDA .cursor/x LDZ2 SWP2 SUB2 .move-cursor/x STZ2
  #0008 .move-cursor/y STZ2
  ;draw/cursor JSR2
  .cursor/x LDZ2 .Screen/x DEO2
  .cursor/y LDZ2 .Screen/y DEO2
  ;backspace .Screen/addr DEO2
  #00 .Screen/sprite DEO
  #000f .Screen/y DEO2
  ;backspace #0008 ADD2 .Screen/addr DEO2
  #00 .Screen/sprite DEO
  .Screen/x DEI2 #0008 ADD2 .Screen/x DEO2
  #0008 .Screen/y DEO2
  ;backspace .Screen/addr DEO2
  #00 .Screen/sprite DEO
  ( put the last letter of the buffer into char )
  ;buffer ;buffer-pointer LDA2 #0001 SUB2 ADD2 LDA #00 ;char STA2
BRK

@type/url
  .Controller/key DEI
  DUP #0d NEQ ?{ POP ;buffer ;buffer-pointer LDA2 ADD2 CRLF STA2 #01 .Network/state DEO } ( Search if enter is pressed )
  DUP #08 NEQ ?{ ;delete/key JMP2 } ( Backspace )
  ( only store printable chars )
  DUP #1f GTH ?{ DBG BRK }
  DUP #7f LTH ?{ DBG BRK }
  #00 ;char STA2
  ;char ;draw/text JSR2
  ;char LDA ;buffer-pointer LDA2 ;buffer ADD2 STA ( store char in buffer )
  ;buffer-pointer LDA2k INC2 SWP2 STA2 ( increment pointer )
  .cursor/x LDZ2 .search-cursor/x STZ2
BRK

@clear/cursor
  ( send cursor position to screen )
  .cursor/x LDZ2 .Screen/x DEO2
  .cursor/y LDZ2 .Screen/y DEO2
  ( clear sprite from screen )
  ;cursor-icn .Screen/addr DEO2
  #00 .Screen/sprite DEO
JMP2r

@draw/cursor
  ;clear/cursor JSR2
  ( update cursor position )
  .move-cursor/x LDZ2 .cursor/x STZ2
  ( send cursor position to screen )
  .cursor/x LDZ2 .Screen/x DEO2
  .cursor/y LDZ2 .Screen/y DEO2
  ( draw sprite with color 2 )
  ;cursor-icn .Screen/addr DEO2
  #0a .Screen/sprite DEO
JMP2r

@draw/newline
  ( store the point at which the line break occured )
  ;lb-pointer LDA2 ;lb-pointer-max LDA2 LTH2 ?{ #00 SWP2 DUP2 ;line-breaks ;lb-pointer LDA2 ADD2 STA2 ;lb-pointer LDA2 INC2 INC2 ;lb-pointer STA2 SWP2 POP .lines/total LDZ2 INC2 .lines/total STZ2 }
  ;clear/cursor JSR2
  #0010 .cursor/y LDZ2 ADD2 .cursor/y STZ2
  #0008 .cursor/x STZ2
JMP2r

@draw/text ( text* -- )
	[ LIT2 15 -Screen/auto ] DEO
	[ LIT2r 05 -Screen/sprite ]
	&while
		LDAk DUP DUP #18 DEO ?{ POP POP2 POP2r JMP2r }
    DUP #0a NEQ ?{ ;draw/newline JSR2 POP INC2 !&while } ( deal with NL )
    .cursor/x LDZ2 #02e5 LTH2 ?{ ;draw/newline JSR2 } ( check pos of cursor )
		#0000 ROT
    .cursor/x LDZ2 .Screen/x DEO2
    .cursor/y LDZ2 .Screen/y DEO2
		( addr ) DUP2 #50 SFT2 ;glyphs ADD2 .Screen/addr DEO2
		( move ) ;widths ADD2 LDA .cursor/x LDZ2 ADD2
		( draw ) [ DEOkr DEOkr ] .move-cursor/x STZ2
    ;draw/cursor JSR2
    INC2 !&while
JMP2r

