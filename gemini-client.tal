( gemini client for UXN )
|00 @System &vector $2 &pad $6 &r $2 &g $2 &b $2
|0e @System/debug $1
|10 @Console &vector $2 &read $1 &pad $5 &write $1 &error $1
|20 @Screen &vector $2 &width $2 &height $2 &auto $1 &pad $1 &x $2 &y $2 &addr $2 &pixel $1 &sprite $1
|80 @Controller [ &vector $2 &button $1 &key $1 ]
|90 @Mouse &vector $2 &x $2 &y $2 &state $1 &chord $1 &pad $2 &scrollx $2 &scrolly $2
|a0 @Network &vector $2 &state $1 &type $1 &host $2 &port $2 &length $2 &read $2 &write $2 &tls $1

( macros )
%DBG ( -- ) { [ LIT2 01 -System/debug ] DEO }
( print a character to standard output )
%EMIT { .Console/write DEO } ( character -- )
( print a newline )
%NL { #0a EMIT } ( -- )

|0100 ( -> )

    ( set screen size )
  #05dc .Screen/width DEO2 ( width of 1500 )
  #0384 .Screen/height DEO2 ( height of 900 )

    ( set system colors )
    #f4fb .System/r DEO2
    #f36e .System/g DEO2
    #e002 .System/b DEO2
    ( draw a pixel in the screen )
    #0008 .Screen/x DEO2
    #0008 .Screen/y DEO2

    ( Set network callback )
    ;on-network .Network/vector DEO2
    
    ( Configure as TCP client )
    #00 .Network/type DEO
    
    ( Configure TLS on )
    #01 .Network/tls DEO

    ( Set target host and port )
    ;host .Network/host DEO2
    ( port 1965 for gemini )
    #07ad .Network/port DEO2
    
    ( Connect )
    #01 .Network/state DEO

BRK

@print/string ( string* -- )
    LDAk ?{ NL POP2 JMP2r }
    LDAk EMIT
    INC2 !/string

@on-network ( -> )
    .Network/state DEI
    
    DUP #02 EQU ?&connected
    
    POP BRK
    
    &connected
        ( Send gemini URL request )
      #0080 .Network/length DEO2
        ;query .Network/write DEO2
        
        ( Read response )
        #0200 .Network/length DEO2
        ;response .Network/read DEO2
        ;response ;print/string JSR2
        ;response ;uf2/<draw> JSR2
        BRK

@uf2/<draw> ( text* -- )
	[ LIT2 15 -Screen/auto ] DEO
	[ LIT2r 05 -Screen/sprite ]
	&>while
		LDAk DUP DBG ?{ POP POP2 POP2r JMP2r } 
    DUP #0a NEQ DBG ?{ #0010 .Screen/y DEI2 ADD2 .Screen/y DEO2 #0008 .Screen/x DEO2 } ( deal with NL )
		#0000 ROT
		( addr ) DUP2 #50 SFT2 ;&glyphs ADD2 .Screen/addr DEO2
		( move ) ;&widths ADD2 LDA .Screen/x DEI2 ADD2
		( draw ) [ DEOkr DEOkr ] .Screen/x DEO2
		INC2 !&>while
