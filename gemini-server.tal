( gemini server for UXN )
|00 @System &vector $2 &pad $6
|0e @System/debug $1
|10 @Console &vector $2 &read $1 &pad $5 &write $1 &error $1
|a0 @Network &vector $2 &state $1 &type $1 &host $2 &port $2 &length $2 &read $2 &write $2 &tls $1
|b0 @File [ &vector $2 &success $2 &stat $2 &delete $1 &append $1 &name $2 &length $2 &read $2 &write $2 ]

%DBG ( -- ) {
    [ LIT2 01 -System/debug ] DEO }
    
( print a character to network output )
%EMIT { .Console/write DEO } ( character -- )

( print a newline )
%NL { #0a EMIT } ( -- )

|0100 ( -> )

    ( Set network callback )
    ;on-network .Network/vector DEO2
    
    ( Configure as TCP server )
    #01 .Network/type DEO
    
    ( Configure TLS to on )
    #01 .Network/tls DEO

    ( Listen on port 1965 )
    #07ad .Network/port DEO2
    
    ( Start listening )
    #02 .Network/state DEO

BRK

@on-network
    .Network/state DEI
    
    DUP #03 EQU ?&accept-client
    DUP #02 EQU ?&handle-client

    POP BRK

    &accept-client
        #04 .Network/state DEO  ( Accept connection )
        POP BRK

    &handle-client
        #0080 .Network/length DEO2
        ;buffer .Network/read DEO2 POP2 ( Read in client message )
        ;buffer ;location ;check/request JSR2
        !load-file


@check/request ( buffer* location* -- )
    LDAk ?{ POP2 POP2 JMP2r }
    LDAk #00
    ROT2
    LDAk #00
    ROT2 POP SWP POP
    EQU ?{ POP2 POP2 BRK } ( give error for invalid request here )
    INC2 SWP2 INC2 !/request

@query/store ( query* buffer* -- )
    #0017 ADD2
    LDAk ?{ POP2 JMP2r }
    SWP2
    #0007 ADD2
    SWP2
    LDAk #00
    ROT2 ROT POP
    STAk ROT POP
    #0007 SUB2
    INC2 SWP2
    #0017 SUB2
    INC2 !/store


@print/string ( string* -- )
    LDAk ?{ NL POP2 JMP2r }
    LDAk EMIT
    INC2 !/string

@load-file
    ;query ;buffer ;query/store JSR2
    ;query .File/name DEO2
    #ffff .File/length DEO2
    ;file/data .File/read DEO2
    .File/success DEI2 #0000 EQU2 ,&failed JCN

    &success
        LIT "Y .Console/write DEO NL
        ;file/data ;print/string JSR2
        ;file/data .Network/write DEO2
        BRK

    &failed
        LIT "N .Console/write DEO NL
        ;failure .Network/write DEO2
        BRK


@location "gemini://glossygem.net/ 00
@success "Valid 20 "URL 20 "received. 0a
@query "gemini/ $20
@buffer $80
@failure "Invalid 20 "URL 20 "received. 20 "This 20 "server 20 "accepts 20 "requests 20 "of 20 "the 20 "form 20 "gemini://glossygem.net/pagename 20 "00
@file
    &data $ffff